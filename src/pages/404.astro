---
import Layout from "../layouts/Layout.astro";

const title = "404 · Página no encontrada";
const description = "La página que buscas no existe o ha sido movida.";

const currentYear = new Date().getFullYear();
---

<Layout title={title} description={description}>
  <main class="flex min-h-screen flex-col">
    <section class="flex flex-1 items-center px-6 pt-32 md:px-10">
      <div class="mx-auto w-full max-w-5xl">
        <p class="eyebrow reveal text-accent">Error 404</p>

        <h1
          class="display reveal mt-6 text-[clamp(7rem,32vw,22rem)] font-light leading-[0.85] tracking-[-0.05em] text-ink dark:text-ink-dark"
        >
          404<span class="text-accent">.</span>
        </h1>

        <div class="mt-8 grid grid-cols-12 gap-y-6 md:gap-x-10">
          <div class="reveal col-span-12 md:col-span-7">
            <h2
              class="display text-[clamp(1.5rem,3.2vw,2.5rem)] font-light leading-tight text-ink dark:text-ink-dark"
            >
              Página
              <span class="italic text-accent">no encontrada</span>
            </h2>
            <p class="mt-4 max-w-prose leading-relaxed text-ink-muted dark:text-ink-dark-muted">
              La página que buscas no existe o ha sido movida. Vuelve al
              portfolio para seguir explorando.
            </p>
          </div>

          <div class="reveal col-span-12 md:col-span-5 md:text-right">
            <a
              href="/"
              class="eyebrow editorial-link inline-flex items-center gap-2 text-ink hover:text-accent dark:text-ink-dark"
            >
              <span aria-hidden="true">←</span>
              Volver al portfolio
            </a>
          </div>
        </div>
      </div>
    </section>

    <footer class="border-t border-line-subtle px-6 py-8 dark:border-line-dark-subtle md:px-10">
      <div class="mx-auto flex max-w-5xl flex-col items-baseline justify-between gap-2 md:flex-row">
        <p class="eyebrow text-ink-muted dark:text-ink-dark-muted">
          © {currentYear} Markel Román González
        </p>
        <p class="eyebrow text-ink-subtle dark:text-ink-dark-subtle">
          Hecho con curiosidad · Bilbao
        </p>
      </div>
    </footer>
  </main>
</Layout>
