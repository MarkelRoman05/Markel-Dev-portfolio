---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = projects.find((p) => p.slug === slug);

if (!project) {
  throw new Error("Proyecto no encontrado");
}
---

<Layout title={`${project.title} · Proyectos`}>
  <Navbar />
  <main class="pt-32 md:pt-40">
    <article class="mx-auto max-w-7xl px-6 md:px-10">
      <a
        href="/#projects"
        class="eyebrow editorial-link inline-flex items-center gap-2 text-ink-muted transition-colors duration-300 hover:text-accent dark:text-ink-dark-muted"
      >
        <span aria-hidden="true">← </span>
        Volver a proyectos
      </a>

      <header class="mt-12 grid grid-cols-12 gap-y-6 md:gap-x-10">
        <div class="col-span-12 md:col-span-3">
          <p class="eyebrow text-accent">Proyecto</p>
        </div>

        <h1
          class="display col-span-12 text-[clamp(2.25rem,6.5vw,5.5rem)] font-light leading-[0.95] tracking-[-0.04em] text-ink dark:text-ink-dark md:col-span-9"
        >
          {project.title}
        </h1>
      </header>

      <div class="reveal mt-16 overflow-hidden border border-line-subtle dark:border-line-dark-subtle">
        <img
          src={project.image}
          alt={project.title}
          class="aspect-[16/9] w-full object-cover grayscale"
        />
      </div>

      <div class="reveal mt-10">
        <p class="eyebrow mb-4 italic text-ink-muted dark:text-ink-dark-muted">Stack tecnológico</p>
        <ul class="flex flex-wrap gap-3">
          {
            project.tags.map((tag) => (
              <li class="eyebrow border border-line-subtle px-4 py-2 text-ink-muted dark:border-line-dark-subtle dark:text-ink-dark-muted">
                {tag}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="reveal mt-7">
        <p class="eyebrow mb-4 italic text-ink-muted dark:text-ink-dark-muted">Descripción</p>
        <p
          class="display text-[clamp(1.125rem,1.8vw,1.5rem)] font-light leading-relaxed text-ink dark:text-ink-dark"
        >
          {project.description}
        </p>
      </div>

      {
        (project.liveUrl || project.codeUrl) && (
          <section class="mt-10 grid grid-cols-12 gap-y-10 border-t border-line-subtle pt-12 dark:border-line-dark-subtle md:gap-x-10">
            <div class="reveal col-span-12 md:col-span-3">
              <p class="eyebrow italic text-ink-muted dark:text-ink-dark-muted">Enlaces</p>
            </div>
            <div class="col-span-12 flex flex-col gap-4 md:col-span-9">
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group inline-flex items-center gap-4 border border-line-subtle px-5 py-4 text-ink transition-colors duration-300 hover:border-accent hover:text-accent dark:border-line-dark-subtle dark:text-ink-dark"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="h-7 w-7 shrink-0"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                    />
                  </svg>
                  <span class="display text-[clamp(1rem,1.4vw,1.25rem)] font-light leading-none tracking-tight">
                    Ver proyecto en vivo
                  </span>
                  <span class="ml-auto text-accent transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
                </a>
              )}
              {project.codeUrl && (
                <a
                  href={project.codeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group inline-flex items-center gap-4 border border-line-subtle px-5 py-4 text-ink transition-colors duration-300 hover:border-accent hover:text-accent dark:border-line-dark-subtle dark:text-ink-dark"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="h-7 w-7 shrink-0"
                    aria-hidden="true"
                  >
                    <path
                      d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.8 1.18 1.83 1.18 3.09 0 4.43-2.7 5.4-5.27 5.68.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.13 0 .31.21.68.8.56C20.22 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
                    ></path>
                  </svg>
                  <span class="display text-[clamp(1rem,1.4vw,1.25rem)] font-light leading-none tracking-tight">
                    Ver código fuente en GitHub
                  </span>
                  <span class="ml-auto text-accent transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
                </a>
              )}
            </div>
          </section>
        )
      }

      <section class="mt-24 flex flex-col gap-6 border-t border-line-subtle pb-12 pt-12 dark:border-line-dark-subtle md:flex-row md:items-baseline md:justify-between">
        <p class="eyebrow text-ink-muted dark:text-ink-dark-muted">
          Fin del proyecto
        </p>
      </section>
    </article>
  </main>
  <Footer />
</Layout>
