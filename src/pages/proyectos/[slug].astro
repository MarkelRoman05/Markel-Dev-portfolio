---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = projects.find((p) => p.slug === slug);

if (!project) {
  throw new Error("Proyecto no encontrado");
}
---

<Layout title={`${project.title} · Proyectos`}>
  <Navbar />
  <main class="pt-32 md:pt-40">
    <article class="mx-auto max-w-7xl px-6 md:px-10">
      <a
        href="/#projects"
        class="eyebrow editorial-link inline-flex items-center gap-2 text-ink-muted transition-colors duration-300 hover:text-accent dark:text-ink-dark-muted"
      >
        <span aria-hidden="true">←</span>
        Volver a proyectos
      </a>

      <header class="mt-12 grid grid-cols-12 gap-y-6 md:gap-x-10">
        <div class="col-span-12 md:col-span-3">
          <p class="eyebrow text-accent">Proyecto</p>
          <p class="eyebrow mt-2 text-ink-muted dark:text-ink-dark-muted">
            {project.tags[0]}
          </p>
        </div>

        <h1
          class="display col-span-12 text-[clamp(2.25rem,6.5vw,5.5rem)] font-light leading-[0.95] tracking-[-0.04em] text-ink dark:text-ink-dark md:col-span-9"
        >
          {project.title}
        </h1>
      </header>

      <div class="reveal mt-16 overflow-hidden border border-line-subtle dark:border-line-dark-subtle">
        <img
          src={project.image}
          alt={project.title}
          class="aspect-[16/9] w-full object-cover grayscale"
        />
      </div>

      <section class="mt-20 grid grid-cols-12 gap-y-10 md:gap-x-10">
        <aside class="reveal col-span-12 md:col-span-3">
          <p class="eyebrow text-ink-muted dark:text-ink-dark-muted">
            Stack
          </p>
          <ul class="mt-4 flex flex-col gap-2">
            {
              project.tags.map((tag) => (
                <li class="eyebrow text-ink dark:text-ink-dark">
                  — {tag}
                </li>
              ))
            }
          </ul>
        </aside>

        <div class="reveal col-span-12 md:col-span-9">
          <p
            class="display text-[clamp(1.125rem,1.8vw,1.5rem)] font-light leading-relaxed text-ink dark:text-ink-dark"
          >
            {project.description}
          </p>
        </div>
      </section>

      {
        (project.liveUrl || project.codeUrl) && (
          <section class="mt-20 grid grid-cols-12 gap-y-10 border-t border-line-subtle pt-12 dark:border-line-dark-subtle md:gap-x-10">
            <div class="reveal col-span-12 md:col-span-3">
              <p class="eyebrow text-ink-muted dark:text-ink-dark-muted">Enlaces</p>
            </div>
            <div class="col-span-12 flex flex-col gap-4 md:col-span-9 md:flex-row md:gap-6">
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="eyebrow editorial-link inline-flex items-baseline gap-2 text-ink transition-colors duration-300 hover:text-accent dark:text-ink-dark"
                >
                  <span class="text-accent" aria-hidden="true">↗</span>
                  Ver proyecto en vivo
                </a>
              )}
              {project.codeUrl && (
                <a
                  href={project.codeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="eyebrow editorial-link inline-flex items-baseline gap-2 text-ink transition-colors duration-300 hover:text-accent dark:text-ink-dark"
                >
                  <span class="text-accent" aria-hidden="true">↗</span>
                  Código fuente
                </a>
              )}
            </div>
          </section>
        )
      }

      <section class="mt-24 flex flex-col gap-6 border-t border-line-subtle pt-12 dark:border-line-dark-subtle md:flex-row md:items-baseline md:justify-between">
        <p class="eyebrow text-ink-muted dark:text-ink-dark-muted">
          Fin del proyecto
        </p>
        <a
          href="/#projects"
          class="eyebrow editorial-link inline-flex items-center gap-2 text-ink hover:text-accent dark:text-ink-dark"
        >
          <span aria-hidden="true">←</span>
          Todos los proyectos
        </a>
      </section>
    </article>
  </main>
  <Footer />
</Layout>
