---
const studies = [
  {
    title: "Máster FP en Inteligencia Artificial y Big Data",
    institution: "iFP — Centro de Formación Profesional",
    period: "oct. 2025 — may. 2026",
    description:
      "Especialización avanzada en inteligencia artificial y análisis de big data. Desarrollo de modelos de machine learning, procesamiento de grandes volúmenes de datos e implementación de soluciones de IA.",
    subjects: ["Machine Learning", "Deep Learning", "Python", "IA y Big Data"],
  },
  {
    title: "Máster FP en Desarrollo de Aplicaciones en Lenguaje Python",
    institution: "CIFP Elorrieta-Erreka Mari LHII",
    period: "sep. 2025 — abr. 2026",
    description:
      "Formación especializada en desarrollo de aplicaciones con Python, utilizando las mejores prácticas y herramientas del ecosistema Python.",
    subjects: ["Python", "PyCharm", "VSCode"],
  },
  {
    title: "Grado Superior en Desarrollo de Aplicaciones Multiplataforma (DAM)",
    institution: "CIFP Elorrieta-Erreka Mari LHII",
    period: "sep. 2023 — may. 2025",
    description:
      "Formación integral en desarrollo de aplicaciones para diferentes plataformas. Proyecto final centrado en una aplicación completa con frontend y backend.",
    subjects: [
      "Java",
      "Android",
      "TypeScript",
      "Node.js",
      "Angular",
      "SQL",
      "Git",
    ],
  },
  {
    title:
      "Grado Superior en Administración de Sistemas Informáticos en Red (ASIR)",
    institution: "CIFP Elorrieta-Erreka Mari LHII",
    period: "sep. 2021 — may. 2023",
    description:
      "Especialización en administración y mantenimiento de sistemas informáticos y redes. Gestión de servidores Windows y Linux, configuración de redes y seguridad.",
    subjects: [
      "Windows Server",
      "Linux",
      "Active Directory",
      "Redes",
      "PowerShell",
      "Virtualización",
    ],
  },
];

const yearRange = (period: string) => {
  const matches = period.match(/\d{4}/g);
  if (!matches) return period;
  return matches.join("—");
};
---

<section id="studies" class="relative border-t border-line-subtle py-24 dark:border-line-dark-subtle md:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <header
      class="reveal grid grid-cols-12 items-end gap-6 border-b border-line-subtle pb-8 dark:border-line-dark-subtle md:gap-10"
    >
      <div class="col-span-12 flex items-baseline gap-6 md:col-span-4">
        <span class="eyebrow text-accent">§ 02</span>
        <span class="eyebrow text-ink-muted dark:text-ink-dark-muted">Formación</span>
      </div>
      <h2
        class="display col-span-12 text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-[1.1] text-ink dark:text-ink-dark md:col-span-8"
      >
        Mi trayectoria
        <span class="italic text-accent"> educativa </span>
        en el ámbito tecnológico.
      </h2>
    </header>

    <ol class="mt-12 space-y-16">
      {
        studies.map((study, index) => (
          <li
            class="reveal grid grid-cols-12 gap-y-4 md:gap-x-10"
            style={`transition-delay: ${index * 80}ms`}
          >
            <div class="col-span-12 md:col-span-3">
              <div class="eyebrow text-ink-muted dark:text-ink-dark-muted">
                {String(index + 1).padStart(2, "0")} ·
              </div>
              <div class="display mt-2 font-mono text-base font-light text-ink dark:text-ink-dark">
                {study.period}
              </div>
            </div>

            <div class="col-span-12 md:col-span-9">
              <h3 class="display text-[clamp(1.5rem,2.6vw,2.25rem)] font-light leading-tight text-ink dark:text-ink-dark">
                {study.title}
              </h3>
              <p class="mt-2 italic text-ink-muted dark:text-ink-dark-muted">
                {study.institution}
              </p>
              <p class="mt-5 max-w-prose leading-relaxed text-ink-muted dark:text-ink-dark-muted">
                {study.description}
              </p>
              <ul class="mt-6 flex flex-wrap gap-2">
                {study.subjects.map((subject) => (
                  <li class="eyebrow border border-line-subtle px-3 py-1.5 text-ink-muted dark:border-line-dark-subtle dark:text-ink-dark-muted">
                    {subject}
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
