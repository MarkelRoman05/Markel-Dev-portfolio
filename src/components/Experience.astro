---
const experiences = [
  {
    title: "Desarrollo Full Stack y Automatizaciones",
    company: "Perseus Cybersecurity Services",
    period: "jun. 2024 - jun. 2025",
    description:
      "Participación en el desarrollo y despliegue de una aplicación web para mostrar la postura de ciberseguridad de un cliente. Análisis de vulnerabilidades y respuesta a incidentes de seguridad. Automatizaciones utilizando las herramientas de Zoho.",
    technologies: [
      "Microsoft Azure",
      "MS Sentinel",
      "Vue.js",
      "Node.js",
      "FastAPI",
      "ArangoDB",
      "Docker",
      "Git",
      "Zoho",
    ],
  },
  {
    title: "Administrador de Sistemas de TI",
    company: "Clínica IMQ Zorrotzaurre · Grupo IMQ",
    period: "jun. 2023 - ago. 2023",
    description:
      "Gestión de usuarios en Active Directory y Microsoft Entra ID, con sincronización On-premise. Automatización de procesos mediante PowerShell, incluyendo cifrado con BitLocker y notificaciones de caducidad de contraseñas. Manejo de incidencias internas y gestión de activos de TI con herramientas ITAM, ITSM y Service Desk.",
    technologies: [
      "Active Directory",
      "PowerShell",
      "BitLocker",
      "Microsoft Azure",
      "VMware vSphere",
      "Visual Studio Code",
    ],
  },
];
---

<section id="experience" class="py-24 bg-white dark:bg-surface-dark">
  <div class="container px-4 mx-auto">
    <div class="mb-16 text-center" data-aos="fade-up">
      <h2 class="mb-4 text-4xl font-bold">Experiencia</h2>
      <div class="w-24 h-1 mx-auto rounded-full gradient-bg"></div>
      <p class="max-w-2xl mx-auto mt-4 text-gray-600 dark:text-gray-400">
        Mi trayectoria laboral tanto en el ámbito del desarrollo como en el de Admistración de Sistemas.
      </p>
    </div>

    <div class="max-w-4xl mx-auto space-y-8">
      {
        experiences.map((exp, index) => (
          <div
            class="relative group"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary via-secondary to-transparent group-hover:scale-x-110 transition-transform duration-300" />
            <div class="relative ml-20">
              <div class="absolute -left-14 top-6 w-8 h-8 rounded-full bg-gradient-to-r from-primary to-secondary flex items-center justify-center shadow-lg">
                <div class="w-3 h-3 bg-white rounded-full" />
              </div>
              <div class="p-6 rounded-2xl bg-gray-50 dark:bg-white/5 shadow-card dark:shadow-card-dark hover:shadow-glow-primary transition-all duration-300">
                <div class="flex flex-wrap items-start justify-between mb-4 gap-4">
                  <div>
                    <h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-2">
                      {exp.title}
                    </h3>
                    <p class="text-lg font-medium text-primary dark:text-secondary">
                      {exp.company}
                    </p>
                  </div>
                  <span class="px-4 py-1.5 text-sm rounded-full bg-primary/10 text-primary dark:bg-secondary/10 dark:text-secondary font-medium flex items-center gap-2">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class="w-4 h-4"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z"
                      />
                    </svg>
                    {exp.period}
                  </span>
                </div>
                <p class="mb-4 text-gray-600 dark:text-gray-400 leading-relaxed">
                  {exp.description}
                </p>
                <div class="flex flex-wrap gap-2">
                  {exp.technologies.map((tech) => (
                    <span class="px-3 py-1.5 text-sm rounded-lg bg-gray-200/50 dark:bg-white/10 text-gray-700 dark:text-gray-300 hover:bg-primary/10 hover:text-primary dark:hover:bg-secondary/10 dark:hover:text-secondary transition-colors">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
