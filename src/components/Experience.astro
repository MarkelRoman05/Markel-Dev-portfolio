---
const experiences = [
  {
    title: "Desarrollo Full Stack y Automatizaciones",
    company: "Perseus Cybersecurity Services",
    period: "jun. 2024 — jun. 2025",
    description:
      "Participación en el desarrollo y despliegue de una aplicación web para mostrar la postura de ciberseguridad de un cliente. Análisis de vulnerabilidades y respuesta a incidentes de seguridad. Automatizaciones utilizando las herramientas de Zoho.",
    technologies: [
      "Microsoft Azure",
      "MS Sentinel",
      "Vue.js",
      "Node.js",
      "FastAPI",
      "ArangoDB",
      "Docker",
      "Git",
      "Zoho",
    ],
  },
  {
    title: "Administrador de Sistemas de TI",
    company: "Clínica IMQ Zorrotzaurre · Grupo IMQ",
    period: "jun. 2023 — ago. 2023",
    description:
      "Gestión de usuarios en Active Directory y Microsoft Entra ID, con sincronización On-premise. Automatización de procesos mediante PowerShell, incluyendo cifrado con BitLocker y notificaciones de caducidad de contraseñas. Manejo de incidencias internas y gestión de activos de TI con herramientas ITAM, ITSM y Service Desk.",
    technologies: [
      "Active Directory",
      "PowerShell",
      "BitLocker",
      "Microsoft Azure",
      "VMware vSphere",
      "Visual Studio Code",
    ],
  },
];
---

<section id="experience" class="relative border-t border-line-subtle py-24 dark:border-line-dark-subtle md:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <header
      class="reveal grid grid-cols-12 items-end gap-6 border-b border-line-subtle pb-8 dark:border-line-dark-subtle md:gap-10"
    >
      <div class="col-span-12 flex items-baseline gap-6 md:col-span-4">
        <span class="eyebrow text-accent">§ 03</span>
        <span class="eyebrow text-ink-muted dark:text-ink-dark-muted">Experiencia</span>
      </div>
      <h2
        class="display col-span-12 text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-[1.1] text-ink dark:text-ink-dark md:col-span-8"
      >
        Mi trayectoria
        <span class="italic text-accent">laboral</span>
        en desarrollo y administración de sistemas.
      </h2>
    </header>

    <ol class="relative mt-16">
      <span
        aria-hidden="true"
        class="absolute bottom-0 left-[10px] top-0 hidden w-px border-l border-dashed border-ink-subtle/40 md:left-[34px] md:block dark:border-ink-dark-subtle/40"
      ></span>

      {
        experiences.map((exp, index) => (
          <li
            class="reveal relative grid grid-cols-12 gap-y-4 pb-16 last:pb-0 md:gap-x-10"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="col-span-12 md:col-span-3">
              <div class="flex items-center gap-4">
                <span
                  aria-hidden="true"
                  class="hidden h-3 w-3 rotate-45 border border-ink bg-ink dark:border-ink-dark dark:bg-ink-dark md:block"
                >
                </span>
                <div>
                  <div class="display text-[clamp(2rem,3.4vw,2.75rem)] font-light leading-none text-ink dark:text-ink-dark">
                    N° {String(index + 1).padStart(2, "0")}
                  </div>
                  <div class="eyebrow mt-2 text-ink-muted dark:text-ink-dark-muted">
                    {exp.period}
                  </div>
                </div>
              </div>
            </div>

            <article class="col-span-12 md:col-span-9">
              <h3 class="display text-[clamp(1.5rem,2.6vw,2.25rem)] font-light leading-tight text-ink dark:text-ink-dark">
                {exp.title}
              </h3>
              <p class="mt-2 italic text-ink-muted dark:text-ink-dark-muted">
                {exp.company}
              </p>
              <p class="mt-5 max-w-prose leading-relaxed text-ink-muted dark:text-ink-dark-muted">
                {exp.description}
              </p>
              <ul class="mt-6 flex flex-wrap gap-2">
                {exp.technologies.map((tech) => (
                  <li class="eyebrow border border-line-subtle px-3 py-1.5 text-ink-muted dark:border-line-dark-subtle dark:text-ink-dark-muted">
                    {tech}
                  </li>
                ))}
              </ul>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>
