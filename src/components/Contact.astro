---

---

<section
  id="contact"
  class="relative border-t border-line-subtle py-24 dark:border-line-dark-subtle md:py-32"
>
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <header
      class="reveal grid grid-cols-12 items-end gap-6 border-b border-line-subtle pb-8 dark:border-line-dark-subtle md:gap-10"
    >
      <div class="col-span-12 flex items-baseline gap-6 md:col-span-4">
        <span class="eyebrow text-accent">§ 06</span>
        <span class="eyebrow text-ink-muted dark:text-ink-dark-muted">Contacto</span>
      </div>
      <h2
        class="display col-span-12 text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-[1.1] text-ink dark:text-ink-dark md:col-span-8"
      >
        ¿Te gustaría
        <span class="italic text-accent">contactar</span>
        conmigo? Escríbeme y te respondo lo antes posible.
      </h2>
    </header>

    <div class="mt-16 grid grid-cols-12 gap-y-10 md:gap-x-10">
      <div class="reveal col-span-12 md:col-span-3">
        <span class="eyebrow text-ink-muted dark:text-ink-dark-muted">Escríbeme</span>
      </div>

      <div class="col-span-12 md:col-span-9">
        <button
          type="button"
          id="email-btn"
          class="group block w-full text-left transition-colors duration-500"
        >
          <span
            class="display block text-[clamp(1.5rem,5.4vw,4.25rem)] font-light leading-[1.05] tracking-tight text-ink transition-colors duration-500 group-hover:text-accent dark:text-ink-dark"
          >
            markromagonz@gmail.com
            <span
              id="email-hint"
              class="ml-2 inline-block text-accent transition-transform duration-500 group-hover:translate-x-2"
              aria-hidden="true"
            >→</span>
          </span>
        </button>
        <p
          id="email-status"
          aria-live="polite"
          class="eyebrow mt-3 h-5 text-ink-muted dark:text-ink-dark-muted"
        >
          Click para copiar
        </p>
      </div>
    </div>

    <div class="mt-16 grid grid-cols-12 gap-y-10 border-t border-line-subtle pt-12 dark:border-line-dark-subtle md:gap-x-10">
      <div class="reveal col-span-12 md:col-span-3">
        <span class="eyebrow text-ink-muted dark:text-ink-dark-muted">Llámame</span>
      </div>

      <div class="col-span-12 md:col-span-9">
        <a
          href="tel:+34688711255"
          class="display block text-[clamp(1.5rem,4.6vw,3.5rem)] font-light leading-[1.05] tracking-tight text-ink transition-colors duration-500 hover:text-accent dark:text-ink-dark"
        >
          +34 688 71 12 55
          <span
            class="ml-2 inline-block text-accent transition-transform duration-500 group-hover:translate-x-2"
            aria-hidden="true"
          >→</span>
        </a>
      </div>
    </div>

    <div class="mt-16 grid grid-cols-12 gap-y-10 border-t border-line-subtle pt-12 dark:border-line-dark-subtle md:gap-x-10">
      <div class="reveal col-span-12 md:col-span-3">
        <span class="eyebrow text-ink-muted dark:text-ink-dark-muted">Sígueme</span>
      </div>

      <div class="col-span-12 md:col-span-9">
        <ul class="flex flex-col gap-3 text-[clamp(1.125rem,2vw,1.5rem)]">
          <li>
            <a
              href="https://github.com/MarkelRoman05"
              target="_blank"
              rel="noopener noreferrer"
              class="display inline-flex items-center gap-3 font-light text-ink transition-colors duration-300 hover:text-accent dark:text-ink-dark"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-5 w-5 shrink-0"
                aria-hidden="true"
              >
                <path
                  d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.8 1.18 1.83 1.18 3.09 0 4.43-2.7 5.4-5.27 5.68.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.13 0 .31.21.68.8.56C20.22 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
                ></path>
              </svg>
              GitHub
              <span class="text-accent" aria-hidden="true">↗</span>
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/markel-rom%C3%A1n-gonz%C3%A1lez/"
              target="_blank"
              rel="noopener noreferrer"
              class="display inline-flex items-center gap-3 font-light text-ink transition-colors duration-300 hover:text-accent dark:text-ink-dark"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-5 w-5 shrink-0"
                aria-hidden="true"
              >
                <path
                  d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.28 2.38 4.28 5.47v6.27zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
                ></path>
              </svg>
              LinkedIn
              <span class="text-accent" aria-hidden="true">↗</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  const email = "markromagonz@gmail.com";
  const btn = document.getElementById("email-btn");
  const status = document.getElementById("email-status");
  const hint = document.getElementById("email-hint");

  const setStatus = (text: string, ok: boolean) => {
    if (!status) return;
    status.textContent = text;
    status.classList.toggle("text-accent", ok);
  };

  const copy = async () => {
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(email);
      } else {
        const t = document.createElement("textarea");
        t.value = email;
        t.style.position = "fixed";
        t.style.opacity = "0";
        document.body.appendChild(t);
        t.select();
        document.execCommand("copy");
        document.body.removeChild(t);
      }
      if (hint) hint.textContent = "✓";
      setStatus("¡Copiado al portapapeles!", true);
    } catch {
      setStatus("No se pudo copiar", false);
    }
    setTimeout(() => {
      if (hint) hint.textContent = "→";
      setStatus("Click para copiar", true);
    }, 2200);
  };

  btn?.addEventListener("click", copy);
</script>
