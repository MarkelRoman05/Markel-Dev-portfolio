---
---

<section id="contact" class="relative overflow-hidden py-24 bg-white dark:bg-surface-dark">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-24 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-80 w-80 rounded-full bg-secondary/10 blur-3xl"></div>
  </div>

  <div class="container relative z-10 px-4 mx-auto">
    <div class="mb-16 text-center" data-aos="fade-up">
      <span class="inline-flex items-center rounded-full bg-primary/10 px-4 py-2 text-sm font-medium text-primary dark:bg-secondary/10 dark:text-secondary">
        Contacto directo
      </span>
      <h2 class="mt-5 text-4xl font-bold text-gray-800 dark:text-white sm:text-5xl">Contacto</h2>
      <div class="w-24 h-1 mx-auto mt-5 rounded-full gradient-bg"></div>
      <p class="max-w-2xl mx-auto mt-5 text-base leading-7 text-gray-600 dark:text-gray-400 sm:text-lg">
        ¿Te gustaría contactar conmigo? Escríbeme y te respondo lo antes posible.
      </p>
    </div>

    <div class="mx-auto max-w-4xl" data-aos="fade-up" data-aos-delay="100">
      <div class="rounded-3xl bg-white dark:bg-white/5 p-6 shadow-card dark:shadow-card-dark sm:p-8">
        <div class="grid gap-6 md:grid-cols-2">
          <button
            type="button"
            id="email-btn"
            class="group flex h-full items-start gap-4 rounded-2xl border border-gray-100 bg-gray-50 p-5 text-left transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:bg-primary/5 dark:border-white/10 dark:bg-white/5 dark:hover:border-secondary/20 dark:hover:bg-secondary/10 cursor-pointer"
          >
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl gradient-bg text-white shadow-glow-secondary transition-transform duration-300 group-hover:scale-105">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="h-6 w-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"></path>
              </svg>
            </div>

            <div class="min-w-0">
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Email</p>
              <p class="font-medium text-gray-800 dark:text-white break-all transition-colors duration-300 group-hover:text-primary dark:group-hover:text-secondary">markromagonz@gmail.com</p>
              <p id="email-copy-text" class="mt-1 text-xs text-primary dark:text-secondary transition-opacity duration-200">Click para copiar</p>
            </div>
          </button>

          <div class="flex items-start gap-4 rounded-2xl border border-gray-100 bg-gray-50 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:bg-primary/5 dark:border-white/10 dark:bg-white/5 dark:hover:border-secondary/20 dark:hover:bg-secondary/10">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl gradient-bg text-white shadow-glow-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="h-6 w-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"></path>
              </svg>
            </div>

            <div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Teléfono</p>
              <p class="font-medium text-gray-800 dark:text-white">+34 688 71 12 55</p>
            </div>
          </div>
        </div>

        <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-lg font-semibold text-gray-800 dark:text-white mb-1">Sígueme en</p>
              <p class="text-gray-600 dark:text-gray-400">También puedes encontrarme aquí</p>
            </div>

            <div class="flex gap-4">
              <a href="https://github.com/MarkelRoman05" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 rounded-2xl bg-gray-100 dark:bg-white/5 px-4 py-3 text-gray-700 dark:text-gray-300 shadow-card dark:shadow-card-dark transition-all duration-300 hover:-translate-y-1 hover:text-primary dark:hover:text-secondary hover:bg-white dark:hover:bg-white/10">
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-white dark:bg-white/10 shadow-sm transition-colors duration-300 group-hover:bg-primary/10 dark:group-hover:bg-white/15">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
                  </svg>
                </span>
                <span class="hidden sm:block">
                  <span class="block text-sm font-medium">GitHub</span>
                  <span class="block text-xs text-gray-500 dark:text-gray-400">Repos y proyectos</span>
                </span>
              </a>
              <a href="https://www.linkedin.com/in/markel-rom%C3%A1n-gonz%C3%A1lez/" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 rounded-2xl bg-gray-100 dark:bg-white/5 px-4 py-3 text-gray-700 dark:text-gray-300 shadow-card dark:shadow-card-dark transition-all duration-300 hover:-translate-y-1 hover:text-primary dark:hover:text-secondary hover:bg-white dark:hover:bg-white/10">
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-white dark:bg-white/10 shadow-sm transition-colors duration-300 group-hover:bg-primary/10 dark:group-hover:bg-white/15">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
                  </svg>
                </span>
                <span class="hidden sm:block">
                  <span class="block text-sm font-medium">LinkedIn</span>
                  <span class="block text-xs text-gray-500 dark:text-gray-400">Contacto profesional</span>
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const emailBtn = document.getElementById('email-btn');
  const emailCopyText = document.getElementById('email-copy-text');

  const email = 'markromagonz@gmail.com';

  const copyEmailToClipboard = async () => {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(email);
      return;
    }

    const tempInput = document.createElement('textarea');
    tempInput.value = email;
    tempInput.setAttribute('readonly', 'true');
    tempInput.style.position = 'fixed';
    tempInput.style.opacity = '0';
    document.body.appendChild(tempInput);
    tempInput.select();
    document.execCommand('copy');
    document.body.removeChild(tempInput);
  };

  if (!emailBtn || !emailCopyText) {
    console.warn('Contact email elements are missing');
  } else {
    emailBtn.addEventListener('click', async () => {
      try {
        await copyEmailToClipboard();
        emailCopyText.textContent = '¡Copiado!';
        emailCopyText.classList.add('text-green-600', 'dark:text-green-400');
        emailCopyText.classList.remove('text-primary', 'dark:text-secondary');
      } catch {
        emailCopyText.textContent = 'No se pudo copiar';
        emailCopyText.classList.remove('text-primary', 'dark:text-secondary');
        emailCopyText.classList.add('text-red-600', 'dark:text-red-400');
      }

      setTimeout(() => {
        emailCopyText.textContent = 'Click para copiar';
        emailCopyText.classList.remove('text-green-600', 'dark:text-green-400', 'text-red-600', 'dark:text-red-400');
        emailCopyText.classList.add('text-primary', 'dark:text-secondary');
      }, 2000);
    });
  }
</script>