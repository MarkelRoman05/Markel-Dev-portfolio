---
const skills = [
  { name: "Angular", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/angularjs/angularjs-original.svg" },
  { name: "Vue.js", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg" },
  { name: "Astro", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-plain.svg", darkLogo: "/astro-original-white.svg" },
  { name: "JavaScript", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" },
  { name: "TypeScript", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" },
  { name: "Python", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" },
  { name: "Tailwind CSS", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg" },
  { name: "Node.js", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg" },
  { name: "Java", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/java/java-original.svg" },
  { name: "MySQL", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg" },
  { name: "Firebase", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/firebase/firebase-plain.svg" },
  { name: "ArangoDB", logo: "https://cdn.worldvectorlogo.com/logos/arangodb.svg" },
  { name: "Git", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg" },
  { name: "GitHub", logo: "https://github.githubassets.com/favicons/favicon.svg", darkLogo: "https://github.githubassets.com/favicons/favicon-dark.svg" },
  { name: "AWS", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/amazonwebservices/amazonwebservices-original-wordmark.svg" },
  { name: "Docker", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg" },
  { name: "Windows", logo: "https://upload.wikimedia.org/wikipedia/commons/c/c7/Windows_logo_-_2012.png" },
  { name: "Linux", logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/linux/linux-original.svg" },
];

const groups: { label: string; items: string[] }[] = [
  { label: "Frontend", items: ["Angular", "Vue.js", "Astro", "TypeScript", "JavaScript", "Tailwind CSS"] },
  { label: "Backend", items: ["Node.js", "Python", "Java"] },
  { label: "Datos", items: ["MySQL", "Firebase", "ArangoDB"] },
  { label: "Cloud & DevOps", items: ["AWS", "Docker", "Git", "GitHub"] },
  { label: "Sistemas", items: ["Linux", "Windows"] },
];

---

<section id="skills" class="relative border-t border-line-subtle py-24 dark:border-line-dark-subtle md:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <header
      class="reveal grid grid-cols-12 items-end gap-6 border-b border-line-subtle pb-8 dark:border-line-dark-subtle md:gap-10"
    >
      <div class="col-span-12 flex items-baseline gap-6 md:col-span-4">
        <span class="eyebrow text-accent">§ 04</span>
        <span class="eyebrow text-ink-muted dark:text-ink-dark-muted">Stack</span>
      </div>
      <h2
        class="display col-span-12 text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-[1.1] text-ink dark:text-ink-dark md:col-span-8"
      >
        Tecnologías y herramientas con las que
        <span class="italic text-accent">trabajo</span>
        habitualmente.
      </h2>
    </header>

    <dl class="mt-12 grid grid-cols-1 gap-y-10 md:grid-cols-12 md:gap-x-10">
      {
        groups.map((group, index) => (
          <div
            class="reveal col-span-12 grid grid-cols-12 gap-4 border-b border-line-subtle pb-10 last:border-0 last:pb-0 dark:border-line-dark-subtle md:gap-10 md:border-0 md:pb-0"
            style={`transition-delay: ${index * 80}ms`}
          >
            <dt class="eyebrow col-span-12 text-ink-muted dark:text-ink-dark-muted md:col-span-3">
              {group.label}
            </dt>
            <dd class="col-span-12 flex flex-wrap items-center gap-4 md:col-span-9">
              {group.items.map((item) => {
                const skill = skills.find((s) => s.name === item);
                const logo = skill?.logo;
                const darkLogo = skill?.darkLogo;
                return (
                  <span class="group inline-flex items-center gap-2.5 border border-line-subtle px-4 py-2.5 transition-colors duration-300 hover:border-accent hover:text-accent dark:border-line-dark-subtle dark:hover:border-accent dark:hover:text-accent">
                    {logo && !darkLogo && (
                      <img
                        src={logo}
                        alt={`${item} logo`}
                        class="h-5 w-5 shrink-0 object-contain"
                        loading="lazy"
                      />
                    )}
                    {darkLogo && (
                      <>
                        <img
                          src={logo}
                          alt={`${item} logo`}
                          class="block h-5 w-5 shrink-0 object-contain dark:hidden"
                          loading="lazy"
                        />
                        <img
                          src={darkLogo}
                          alt={`${item} logo`}
                          class="hidden h-5 w-5 shrink-0 object-contain dark:block"
                          loading="lazy"
                        />
                      </>
                    )}
                    <span class="display text-[clamp(0.875rem,1.2vw,1.125rem)] font-light leading-none text-ink group-hover:text-accent dark:text-ink-dark dark:group-hover:text-accent">
                      {item}
                    </span>
                  </span>
                );
              })}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
