---
const currentYear = new Date().getFullYear();
---

<section
  id="home"
  class="relative flex min-h-screen flex-col overflow-hidden pt-32 pb-16 md:pt-40 md:pb-24"
>
  <div class="mx-auto w-full max-w-7xl flex-1 px-6 md:px-10">
    <div class="grid grid-cols-12 gap-y-12 md:gap-x-8">
      <div class="col-span-12 reveal md:col-span-8">
        <div
          class="flex items-center gap-3 text-ink-muted dark:text-ink-dark-muted"
        >
          <span class="relative grid h-2.5 w-2.5 place-items-center">
            <span
              class="absolute inset-0 animate-ping rounded-full bg-accent opacity-60"
            ></span>
            <span class="relative h-1.5 w-1.5 rounded-full bg-accent"></span>
          </span>
          <span class="eyebrow">Disponible para trabajar</span>
        </div>

        <h1
          class="display mt-10 text-[clamp(3.25rem,12vw,10.5rem)] font-light leading-[0.88] tracking-[-0.04em] text-ink dark:text-ink-dark"
        >
          Markel<br />
          Román<span class="text-accent">.</span>
          <span
            class="display italic font-extralight text-ink-muted dark:text-ink-dark-muted"
          >
            González
          </span>
        </h1>

        <p
          class="display mt-10 max-w-2xl text-[clamp(1.25rem,2.2vw,1.875rem)] font-extralight leading-snug italic text-ink dark:text-ink-dark"
        >
          Desarrollador y Administrador de Sistemas — construyendo
          <span class="text-accent">soluciones escalables</span> y explorando nuevas
          tecnologías.
        </p>

        <div class="mt-14 flex flex-wrap items-stretch gap-4">
          <a
            href="https://www.linkedin.com/in/markel-rom%C3%A1n-gonz%C3%A1lez/"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex flex-1 items-center gap-4 border border-line-subtle px-5 py-4 text-ink transition-colors duration-300 hover:border-accent hover:text-accent dark:border-line-dark-subtle dark:text-ink-dark sm:flex-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-8 w-8 shrink-0"
              aria-hidden="true"
            >
              <path
                d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.28 2.38 4.28 5.47v6.27zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
              ></path>
            </svg>
            <span
              class="display text-[clamp(1.125rem,1.6vw,1.5rem)] font-light leading-none tracking-tight"
            >
              LinkedIn
            </span>
            <span
              class="ml-auto text-accent transition-transform duration-300 group-hover:translate-x-1"
              aria-hidden="true">→</span
            >
          </a>
          <a
            href="https://github.com/MarkelRoman05"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex flex-1 items-center gap-4 border border-line-subtle px-5 py-4 text-ink transition-colors duration-300 hover:border-accent hover:text-accent dark:border-line-dark-subtle dark:text-ink-dark sm:flex-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-8 w-8 shrink-0"
              aria-hidden="true"
            >
              <path
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.8 1.18 1.83 1.18 3.09 0 4.43-2.7 5.4-5.27 5.68.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.13 0 .31.21.68.8.56C20.22 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
              ></path>
            </svg>
            <span
              class="display text-[clamp(1.125rem,1.6vw,1.5rem)] font-light leading-none tracking-tight"
            >
              GitHub
            </span>
            <span
              class="ml-auto text-accent transition-transform duration-300 group-hover:translate-x-1"
              aria-hidden="true">→</span
            >
          </a>
          <button
            type="button"
            id="hero-email"
            class="group inline-flex flex-1 items-center gap-4 self-stretch border border-line-subtle px-5 py-4 text-left text-ink transition-colors duration-300 hover:border-accent hover:text-accent dark:border-line-dark-subtle dark:text-ink-dark sm:flex-none"
            title="Haz clic para copiar"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="h-8 w-8 shrink-0"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
              ></path>
            </svg>
            <span class="flex min-w-0 flex-col leading-tight">
              <span
                class="eyebrow text-ink-muted transition-colors group-hover:text-accent dark:text-ink-dark-muted"
                >Email</span
              >
              <span
                id="hero-email-label"
                class="display truncate text-[clamp(1rem,1.4vw,1.25rem)] font-light tracking-tight"
              >
                markromagonz@gmail.com
              </span>
            </span>
            <span
              id="hero-email-hint"
              class="ml-auto text-accent transition-transform duration-300 group-hover:translate-x-1"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                class="h-7 w-7"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75"
                />
              </svg>
            </span>
          </button>
        </div>
      </div>

      <aside
        class="col-span-12 reveal self-end md:col-span-4 md:translate-y-12 lg:translate-y-16"
        style="transition-delay: 120ms"
      >
        <figure class="relative ml-auto w-full max-w-xs md:max-w-sm">
          <div
            class="absolute -left-3 -top-3 h-12 w-12 border-t-2 border-l-2 border-accent"
            aria-hidden="true"
          >
          </div>
          <div
            class="absolute -bottom-3 -right-3 h-12 w-12 border-b-2 border-r-2 border-accent"
            aria-hidden="true"
          >
          </div>
          <div class="overflow-hidden bg-ink dark:bg-paper">
            <img
              src="/Markel_image.jpeg"
              alt="Markel Román González"
              class="aspect-[3/4] w-full object-cover grayscale contrast-110"
              loading="eager"
            />
          </div>
          <figcaption
            class="eyebrow mt-4 flex items-baseline justify-between text-ink-muted dark:text-ink-dark-muted"
          >
            <span>Bilbao · ES</span>
            <span class="text-accent">·</span>
          </figcaption>
        </figure>
      </aside>
    </div>
  </div>

  <div class="mx-auto w-full max-w-7xl px-6 md:px-10">
    <div
      class="reveal mt-16 flex items-end justify-between border-t border-line-subtle pt-6 dark:border-line-dark-subtle"
    >
      <a
        href="#about"
        class="group inline-flex items-center gap-3 text-ink-muted transition-colors hover:text-accent dark:text-ink-dark-muted"
      >
        <span class="eyebrow">Continuar</span>
        <span
          aria-hidden="true"
          class="inline-block translate-y-0 transition-transform duration-500 group-hover:translate-y-1"
          >↓</span
        >
      </a>
      <p
        class="eyebrow hidden text-right text-ink-subtle dark:text-ink-dark-subtle md:block"
      >
        Portfolio · v{currentYear}
      </p>
    </div>
  </div>
</section>

<script>
  const email = "markromagonz@gmail.com";
  const btn = document.getElementById("hero-email");
  const hint = document.getElementById("hero-email-hint");

  const ICONS = {
    copy: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-7 w-7" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75"/></svg>`,
    check: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-7 w-7" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>`,
    error: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-7 w-7" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>`,
  };

  let resetTimer: number | undefined;
  const setIcon = (key: keyof typeof ICONS) => {
    if (!hint) return;
    hint.innerHTML = ICONS[key];
    window.clearTimeout(resetTimer);
    if (key !== "copy") {
      resetTimer = window.setTimeout(() => setIcon("copy"), 1800);
    }
  };

  const copy = async () => {
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(email);
      } else {
        const t = document.createElement("textarea");
        t.value = email;
        t.style.position = "fixed";
        t.style.opacity = "0";
        document.body.appendChild(t);
        t.select();
        document.execCommand("copy");
        document.body.removeChild(t);
      }
      setIcon("check");
    } catch {
      setIcon("error");
    }
  };

  btn?.addEventListener("click", copy);
</script>
