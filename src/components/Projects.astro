---
import { projects } from "../data/projects";

function truncate(text: string, maxLength = 180) {
  if (!text) return "";
  return text.length > maxLength ? text.slice(0, maxLength).trimEnd() + "..." : text;
}
---

<section id="projects" class="relative border-t border-line-subtle py-24 dark:border-line-dark-subtle md:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <header
      class="reveal grid grid-cols-12 items-end gap-6 border-b border-line-subtle pb-8 dark:border-line-dark-subtle md:gap-10"
    >
      <div class="col-span-12 flex items-baseline gap-6 md:col-span-4">
        <span class="eyebrow text-accent">§ 05</span>
        <span class="eyebrow text-ink-muted dark:text-ink-dark-muted">Proyectos</span>
      </div>
      <h2
        class="display col-span-12 text-[clamp(1.75rem,3.6vw,2.75rem)] font-light leading-[1.1] text-ink dark:text-ink-dark md:col-span-8"
      >
        Algunos de los proyectos en los que he
        <span class="italic text-accent"> trabajado </span>
        recientemente.
      </h2>
    </header>

    <ol class="mt-16 space-y-20 md:space-y-28">
      {
        projects.map((project, index) => {
          const number = String(index + 1).padStart(2, "0");
          const imageFirst = index % 2 === 0;
          return (
            <li
              class="reveal grid grid-cols-12 items-center gap-y-6 md:gap-x-10"
              style={`transition-delay: ${index * 80}ms`}
            >
              <a
                href={`/proyectos/${project.slug}/`}
                class={`group relative col-span-12 block overflow-hidden border border-line-subtle dark:border-line-dark-subtle md:col-span-7 ${
                  imageFirst ? "md:order-1" : "md:order-2 md:col-start-6"
                }`}
                aria-label={`Ver detalles de ${project.title}`}
              >
                <span
                  aria-hidden="true"
                  class="absolute inset-x-0 top-0 z-10 h-0.5 origin-left scale-x-0 bg-accent transition-transform duration-700 ease-editorial group-hover:scale-x-100"
                >
                </span>
                <img
                  src={project.image}
                  alt={project.title}
                  class="aspect-[16/10] w-full object-cover grayscale transition duration-700 ease-editorial group-hover:grayscale-0 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </a>

              <div
                class={`col-span-12 md:col-span-5 ${
                  imageFirst ? "md:order-2" : "md:order-1 md:row-start-1"
                }`}
              >
                <div class="eyebrow flex items-baseline gap-3 text-ink-muted dark:text-ink-dark-muted">
                  <span class="display text-base font-light text-accent">N° {number}</span>
                  <span aria-hidden="true">·</span>
                  <span>Proyecto</span>
                </div>

                <h3 class="display mt-4 text-[clamp(1.75rem,3.2vw,2.5rem)] font-light leading-[1.05] text-ink dark:text-ink-dark">
                  <a
                    href={`/proyectos/${project.slug}/`}
                    class="transition-colors duration-300 hover:text-accent"
                  >
                    {project.title}
                  </a>
                </h3>

                <p class="mt-5 max-w-prose leading-relaxed text-ink-muted dark:text-ink-dark-muted">
                  {truncate(project.description)}
                </p>

                <ul class="mt-6 flex flex-wrap gap-2">
                  {project.tags.slice(0, 4).map((tag) => (
                    <li class="eyebrow border border-line-subtle px-3 py-1.5 text-ink-muted dark:border-line-dark-subtle dark:text-ink-dark-muted">
                      {tag}
                    </li>
                  ))}
                </ul>

                <a
                  href={`/proyectos/${project.slug}/`}
                  class="eyebrow editorial-link mt-8 inline-flex items-center gap-2 text-ink hover:text-accent dark:text-ink-dark"
                >
                  Ver proyecto
                </a>
              </div>
            </li>
          );
        })
      }
    </ol>
  </div>
</section>
