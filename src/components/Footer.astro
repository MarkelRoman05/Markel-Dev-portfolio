---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-line-subtle dark:border-line-dark-subtle">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 px-6 py-10 md:flex-row md:items-center md:justify-between md:px-10">
    <p class="eyebrow text-ink-muted dark:text-ink-dark-muted">
      © {currentYear} Markel Román
    </p>

    <a
      id="scroll-top-link"
      href="#home"
      class="eyebrow group inline-flex items-center gap-2 text-ink-muted transition-colors duration-300 hover:text-accent dark:text-ink-dark-muted"
    >
      <span aria-hidden="true" class="inline-block transition-transform duration-500 group-hover:-translate-y-1">↑</span>
      Volver arriba
    </a>

    <p class="eyebrow text-ink-subtle dark:text-ink-dark-subtle">
      Hecho con <span class="text-accent">Astro</span> y <span class="text-accent">Tailwind CSS</span>
    </p>
  </div>
</footer>

<script>
  if (typeof window !== "undefined") {
    const link = document.getElementById("scroll-top-link");
    link?.addEventListener("click", (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>
