---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio personal creado con Astro" } =
  Astro.props;

import { Tooltips } from "astro-tooltips";
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script type="text/javascript">
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "s3ypzeozkw");
    </script>
    <link rel="icon" type="image/x-icon" href="/logo.ico" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <Tooltips interactive={false} delay={[15, 150]} />
    <title>{title}</title>
  </head>
    <body
      class="transition-colors duration-500 bg-light text-slate-800 dark:bg-dark dark:text-slate-200"
    >
      <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
        <div class="absolute top-0 -left-40 w-80 h-80 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 -right-40 w-80 h-80 bg-secondary/10 rounded-full blur-3xl"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent/5 rounded-full blur-3xl"></div>
      </div>
    <slot />
    <script>
      import AOS from "aos";
      import "aos/dist/aos.css";

      AOS.init({
        duration: 800,
        easing: "ease-in-out",
        once: true,
        mirror: false,
        disable: () => window.innerWidth < 768,
      });

      const initializeTheme = () => {
        const savedTheme = localStorage.getItem("MARKEL05_PORTFOLIO:THEME");

        if (
          savedTheme === "dark" ||
          (!savedTheme &&
            window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
          localStorage.setItem("MARKEL05_PORTFOLIO:THEME", "dark");
        } else {
          document.documentElement.classList.remove("dark");
          localStorage.setItem("MARKEL05_PORTFOLIO:THEME", "light");
        }
      };

      initializeTheme();

      document.addEventListener("themeToggle", () => {
        const isDark = document.documentElement.classList.contains("dark");

        if (isDark) {
          document.documentElement.classList.remove("dark");
          localStorage.setItem("MARKEL05_PORTFOLIO:THEME", "light");
        } else {
          document.documentElement.classList.add("dark");
          localStorage.setItem("MARKEL05_PORTFOLIO:THEME", "dark");
        }
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: "Inter", system-ui, sans-serif;
    overflow-x: hidden;
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    overflow-x: hidden;
  }

  @media (max-width: 767px) {
    [data-aos] {
      transform: none !important;
      opacity: 1 !important;
    }
  }

  .gradient-text {
    background: linear-gradient(135deg, #0d9488 0%, #059669 50%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: gradient 4s ease infinite;
  }

  .gradient-bg {
    background: linear-gradient(135deg, #0d9488 0%, #059669 50%, #06b6d4 100%);
    background-size: 200% 200%;
    animation: gradient 4s ease infinite;
  }

  @keyframes gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  ::selection {
    background: rgba(13, 148, 136, 0.3);
    color: inherit;
  }
</style>